generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Feedback {
  id        String   @id @default(uuid())
  name      String   @default("Anonymous")
  rating    Int      @default(5)
  comment   String
  images    String[] @default([])
  date      DateTime @default(now())
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  sentiment String?  // Optional: 'LIKE' or 'DISLIKE'
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float    @default(0)
  images      String[] @default([])
  categoryId  String
  isFeatured  Boolean  @default(false)
  isComingSoon Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id                  String   @id @default(uuid())
  email               String   @unique
  password            String
  username            String
  profilePhoto        String?
  tempPassword        String?
  tempPasswordExpires Float?
  otp                 String?
  otpExpires          Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
